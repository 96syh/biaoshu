# SERP_API_KEY=${SERP_API_KEY}

# 默认关闭生成链路兜底；模型失败、JSON 不完整或超时时直接报错停止。
YIBIAO_ENABLE_GENERATION_FALLBACKS=0

# 默认不接入 MinerU，使用内置 pdfplumber / docx2python / PyPDF2 解析器。
# 如需启用 MinerU，可改为 auto / mineru / mineru_strict。
YIBIAO_DOCUMENT_PARSER=legacy

# MinerU 仅在 YIBIAO_DOCUMENT_PARSER 非 legacy 时使用。
YIBIAO_MINERU_TIMEOUT=900

# 默认优先速度：不在上传阶段额外渲染 DOCX 页图/HTML 预览，不提取图片并上传外部图床。
YIBIAO_ENABLE_SOURCE_PREVIEW_PAGES=0
YIBIAO_ENABLE_DOCX_HTML_PREVIEW=0
YIBIAO_UPLOAD_EXTRACTED_IMAGES=0

# 目录生成默认限制并发，避免本地模型或 LiteLLM 过载；图表素材规划改为前端手动触发。
YIBIAO_OUTLINE_CONCURRENCY=2
YIBIAO_AUTO_DOCUMENT_BLOCKS_PLAN=0

# 可选/遗留能力默认不注册到 FastAPI 主流程。
ENABLE_SEARCH_ROUTER=0
ENABLE_LEGACY_EXPAND_ROUTER=0

# 运行态数据和产物默认放在 artifacts/，避免混入源码目录。
# YIBIAO_PROJECT_DB_PATH=../artifacts/data/projects.sqlite3
# YIBIAO_HISTORY_CASE_DB_PATH=../artifacts/data/history_cases.sqlite3
# YIBIAO_GENERATED_ASSET_DIR=../artifacts/data/generated_assets
# YIBIAO_FRONTEND_STATIC_DIR=../artifacts/build/backend-static
