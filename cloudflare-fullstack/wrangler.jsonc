{
  "name": "yibiao-fullstack",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-31",
  "containers": [
    {
      "class_name": "YibiaoApp",
      "image": "../backend/Dockerfile.cloudflare",
      "instance_type": "standard-2",
      "max_instances": 1
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "APP",
        "class_name": "YibiaoApp"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["YibiaoApp"]
    }
  ]
}
